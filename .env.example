# ── Database ──────────────────────────────────────
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=slcdb
DB_USER=slcuser
DB_PASS=CHANGE_THIS_DB_PASSWORD
DB_ROOT_PASS=CHANGE_THIS_ROOT_PASSWORD

# ── API Server ────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── JWT Secret (generate with: openssl rand -base64 48) ─
JWT_SECRET=CHANGE_THIS_JWT_SECRET

# ── CORS (comma-separated allowed origins) ────────
ALLOWED_ORIGINS=https://your-domain.example.com
